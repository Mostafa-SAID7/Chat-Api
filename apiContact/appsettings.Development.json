{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Debug"
    }
  },
  "Jwt": {
    "Key": "your_super_secret_key_minimum_32_characters_long_for_development",
    "Issuer": "ChatApi",
    "Audience": "ChatApiClient",
    "ExpirationMinutes": 1440
  },
  "ConnectionStrings": {
    "DefaultConnection": "mongodb://localhost:27017/chatdb"
  },
  "MongoDB": {
    "ConnectionString": "mongodb://localhost:27017/chatdb",
    "DatabaseName": "chatdb"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5000",
      "http://0.0.0.0:5000",
      "http://127.0.0.1:5000"
    ]
  },
  "AllowedHosts": "*",
  "Features": {
    "EnableSwagger": true,
    "EnableHealthChecks": true,
    "UseInMemoryDatabase": true
  }
}

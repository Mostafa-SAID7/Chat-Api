modules = ["dotnet-9.0", "web"]

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

# Environment setup for Replit
[env]
JWT_KEY = "your_super_secret_key_minimum_32_characters_long_for_development"
ASPNETCORE_ENVIRONMENT = "Development"
ASPNETCORE_URLS = "http://0.0.0.0:5000"

# Simplified workflow for Replit
[workflows]
runButton = "Run API"

[[workflows.workflow]]
name = "Run API"
mode = "sequential"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apiContact && dotnet restore"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apiContact && dotnet build"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apiContact && dotnet run"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

# Port configuration - Main API
[[ports]]
localPort = 5000
externalPort = 80
description = "Chat API"
expose = true

# Deployment configuration for Replit
[deployment]
deploymentTarget = "autoscale"
run = [
  "dotnet",
  "run",
  "--project",
  "apiContact/apiContact.csproj",
  "--urls",
  "http://0.0.0.0:5000"
]

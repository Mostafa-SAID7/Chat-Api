# ============================================
# JWT Configuration
# ============================================
JWT_KEY=your_super_secret_key_minimum_32_characters_long_for_development

# ============================================
# MongoDB Configuration
# ============================================
MONGO_USERNAME=admin
MONGO_PASSWORD=admin123
# For local development, leave as is
# For production, use MongoDB Atlas connection string
# MONGODB_CONNECTION_STRING=mongodb+srv://user:pass@cluster.mongodb.net/chatdb

# ============================================
# Redis Configuration
# ============================================
REDIS_PASSWORD=redis123
# For production with external Redis:
# REDIS_CONNECTION_STRING=host:port:password

# ============================================
# Application Environment
# ============================================
ASPNETCORE_ENVIRONMENT=Development

# ============================================
# Docker Settings (optional)
# ============================================
# DOCKER_REGISTRY=your-registry
# DOCKER_IMAGE_TAG=latest
